/* Category Bar */
.category-bar {
  padding: 20rpx 28rpx;
}

.category-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-label {
  font-size: 26rpx;
  color: #999;
}

.category-value-wrap {
  display: flex;
  align-items: center;
}

.category-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #4F7CFF;
  margin-right: 8rpx;
}

.arrow-icon {
  font-size: 24rpx;
  color: #4F7CFF;
}

/* Category Picker Overlay */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.picker-list {
  max-height: 60vh;
  padding: 12rpx 0;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-item:active {
  background: #f5f7fa;
}

.picker-item-active {
  color: #4F7CFF;
  font-weight: 600;
}

.check-icon {
  color: #4F7CFF;
  font-size: 32rpx;
}

/* Today Stats Card */
.stats-card {
  text-align: center;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 8rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #4F7CFF;
  line-height: 1.2;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* Feature Grid */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.feature-card {
  width: calc(50% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 20rpx 28rpx;
  box-sizing: border-box;
}

.feature-card:active {
  opacity: 0.8;
}

.feature-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.icon-chapter {
  background: #eef3ff;
}

.icon-random {
  background: #fff3e0;
}

.icon-mock {
  background: #e8f5e9;
}

.icon-wrong {
  background: #fce4ec;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
}

/* Progress Card */
.progress-card {
  margin-top: 0;
}

.progress-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
}

.progress-percent {
  font-size: 28rpx;
  font-weight: 600;
  color: #4F7CFF;
}
