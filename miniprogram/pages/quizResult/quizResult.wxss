.result-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ========== Score Hero ========== */
.score-hero {
  background: linear-gradient(135deg, #4F7CFF, #6C9AFF);
  padding: 60rpx 0 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
}

.score-ring-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-ring {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ring-center {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4F7CFF, #6C9AFF);
  display: flex;
  align-items: baseline;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.score-number {
  font-size: 80rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.score-unit {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 4rpx;
  font-weight: 500;
}

.score-label {
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  margin-top: 20rpx;
  font-weight: 500;
}

/* ========== Stats Row ========== */
.stats-row {
  display: flex;
  margin: -40rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  padding: 32rpx 0;
  position: relative;
  z-index: 10;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stat-card:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 2rpx;
  background: #eee;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-name {
  font-size: 24rpx;
  color: #999;
}

.correct-color {
  color: #43a047;
}

.wrong-color {
  color: #ff5757;
}

/* ========== Wrong Section ========== */
.wrong-section {
  padding: 32rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.wrong-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.wrong-item {
  padding: 24rpx 28rpx;
}

.wrong-question-content {
  display: flex;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.wrong-index {
  font-size: 28rpx;
  color: #999;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.wrong-text {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.wrong-answers {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.answer-row {
  display: flex;
  align-items: center;
}

.answer-label {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.wrong-label {
  background: #fff0f0;
  color: #ff5757;
}

.correct-label {
  background: #e8f5e9;
  color: #43a047;
}

.answer-value {
  font-size: 28rpx;
  color: #666;
}

.wrong-value {
  color: #ff5757;
}

.correct-value {
  color: #43a047;
}

/* ========== All Correct ========== */
.all-correct {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.all-correct-icon {
  font-size: 100rpx;
  color: #ffc107;
  margin-bottom: 20rpx;
}

.all-correct-text {
  font-size: 34rpx;
  color: #333;
  font-weight: 600;
}

/* ========== Bottom Actions ========== */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.action-btn {
  flex: 1;
  margin: 0;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  font-weight: 500;
}
