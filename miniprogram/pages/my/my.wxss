/* 顶部用户区域 */
.user-header {
  background: linear-gradient(135deg, #4F7CFF 0%, #6C8FFF 100%);
  padding: 60rpx 40rpx 50rpx;
  padding-top: calc(60rpx + env(safe-area-inset-top));
}

.user-info-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.user-detail {
  margin-left: 30rpx;
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.phone-row {
  display: flex;
  align-items: center;
}

.phone-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.bind-phone-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #4F7CFF;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  padding: 8rpx 28rpx;
  height: auto;
  line-height: 1.5;
  border: none;
  margin: 0;
}

.bind-phone-btn::after {
  border: none;
}

/* 统计卡片 */
.stats-card {
  margin-top: -30rpx;
  position: relative;
  z-index: 10;
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 10rpx 0;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #4F7CFF;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 22rpx;
  color: #999;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 分类卡片 */
.category-card {
  padding: 24rpx 28rpx;
}

.category-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.category-left {
  display: flex;
  flex-direction: column;
}

.category-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.switch-btn {
  font-size: 26rpx;
  color: #4F7CFF;
  background: #f0f4ff;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

/* 功能列表 */
.menu-card {
  padding: 0;
  overflow: hidden;
}

.menu-cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 28rpx;
}

.menu-cell-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-stats {
  background: #e8f5e9;
}

.menu-icon-about {
  background: #e3f2fd;
}

.icon-text {
  font-size: 30rpx;
}

.menu-cell-title {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.menu-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin-left: 104rpx;
}
